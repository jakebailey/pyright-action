{
    "name": "pyright-action",
    "version": "3.0.2",
    "private": true,
    "description": "GitHub Action for pyright",
    "main": "dist/index.js",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jakebailey/pyright-action.git"
    },
    "author": "Jake Bailey",
    "license": "MIT",
    "engines": {
        "node": ">= 24"
    },
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@actions/http-client": "~4.0.1",
        "@actions/tool-cache": "^4.0.0",
        "@badrap/valita": "^0.5.1",
        "@iarna/toml": "^2.2.5",
        "semver": "^7.8.0",
        "shell-quote": "^1.8.3",
        "tiny-jsonc": "^1.0.2",
        "which": "^7.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node24": "^24.0.4",
        "@tsconfig/strictest": "^2.0.8",
        "@types/node": "^24.12.3",
        "@types/semver": "^7.7.1",
        "@types/shell-quote": "^1.7.5",
        "@types/which": "^3.0.4",
        "@vitest/coverage-v8": "^4.1.6",
        "dprint": "^0.54.0",
        "esbuild": "^0.28.0",
        "eslint": "^10.3.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unicorn": "^65.0.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "klona": "^2.0.6",
        "path-serializer": "^0.6.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.3",
        "vitest": "^4.1.6"
    },
    "scripts": {
        "prepare": "husky",
        "build": "node build.mjs",
        "test": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "release-it": {
        "git": {
            "commitMessage": "Release v${version}",
            "tagName": "v${version}"
        },
        "npm": {
            "publish": false
        },
        "github": {
            "release": true,
            "releaseName": "v${version}",
            "web": true
        },
        "hooks": {
            "before:init": "pnpm run test --run",
            "after:git:release": "(git tag -d v3 && git push origin :refs/tags/v3) || true && git tag v3 && git push origin v3"
        }
    },
    "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14"
}
